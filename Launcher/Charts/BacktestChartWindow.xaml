<Window x:Class="Launcher.Charts.BacktestChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="回測結果"
        Height="800"
        Width="1280"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 統計列：從 BacktestSummary.Stats 填值 -->
        <Border Grid.Row="0"
                Background="#f5f5f5"
                BorderBrush="#dddddd"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatNetProfit"       Margin="0,0,24,0" />
                <TextBlock x:Name="StatSharpe"          Margin="0,0,24,0" />
                <TextBlock x:Name="StatMaxDrawdown"     Margin="0,0,24,0" />
                <TextBlock x:Name="StatTotalTrades"    Margin="0,0,24,0" />
                <TextBlock x:Name="StatWinRate"         Margin="0,0,24,0" />
                <TextBlock x:Name="StatProfitLossRatio" Margin="0,0,24,0" />
            </StackPanel>
        </Border>

        <!-- 動態填入：第一個 tab 是「績效」(權益曲線 + 回撤)，其餘是各 symbol K 線圖 -->
        <TabControl Grid.Row="1" x:Name="Tabs" />
    </Grid>
</Window>
